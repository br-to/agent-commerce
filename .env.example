# EC Server wallet (receives payments)
PAY_TO_ADDRESS=0xYourShopAddressHere

# x402 Facilitator
FACILITATOR_URL=https://x402.org/facilitator

# Server port
PORT=4021

# Agent wallet private key (shopper) - needs USDC on Base Sepolia
AGENT_PRIVATE_KEY=0xYourAgentPrivateKeyHere

# Resource server URL (for agent)
EC_SERVER_URL=http://localhost:4021
